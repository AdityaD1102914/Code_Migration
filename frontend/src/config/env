const config = {
  // API Configuration
  apiBaseUrl: import.meta.env.VITE_API_BASE_URL || "http://localhost:4000",

  // GitHub Configuration
  githubAppUrl:
    import.meta.env.VITE_GITHUB_APP_URL ||
    "https://github.com/apps/Frontend-Xccelerator/installations/new",

  // UI Configuration
  githubPopupConfig: "width=500,height=600,scrollbars=yes,resizable=yes",
  messageAutoDismissDuration: 5000,
};

// Validate required environment variables
const validateConfig = () => {
  const requiredVars = [
    { key: "apiBaseUrl", value: config.apiBaseUrl },
    { key: "githubAppUrl", value: config.githubAppUrl },
  ];

  const missing = requiredVars.filter((v) => !v.value);

  if (missing.length > 0) {
    console.warn(
      "Warning: The following environment variables are using default values:",
      missing.map((v) => v.key)
    );
  }
};

// Validate on load
validateConfig();

export default config;
